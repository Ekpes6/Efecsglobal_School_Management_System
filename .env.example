# EduManage NG — Environment Variables
# Copy this file to .env and fill in the values

# MySQL
MYSQL_ROOT_PASSWORD=your_root_password_here
MYSQL_USER=root
MYSQL_PASSWORD=your_password_here

# JWT Secret (at least 64 hex chars)
JWT_SECRET=3cfa76ef14937c1c0ea519f8fc057a80fcd04a7420f8e8bcd0a7567c272e007b

# Paystack (Nigerian payment gateway — https://paystack.com)
PAYSTACK_SECRET_KEY=sk_live_your_key_here

# Email (Gmail SMTP or any SMTP provider)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# Termii (Nigerian SMS provider — https://termii.com)
TERMII_API_KEY=your_termii_api_key
